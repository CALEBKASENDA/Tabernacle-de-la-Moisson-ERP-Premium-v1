# Copiez ce fichier : cp .env.example .env
# Ou lancez : npm run setup

# ─── Déploiement HTTPS (profil production) ───────────────────────────────────
DOMAIN=erp.votre-domaine.com
ACME_EMAIL=admin@votre-domaine.com

# ─── Église par défaut ─────────────────────────────────────────────────────
TABERNACLE_CHURCH_ID=church_default
TABERNACLE_CHURCH_NAME=Tabernacle de la Moisson

# ─── Données & sécurité ────────────────────────────────────────────────────
TABERNACLE_DATA_DIR=data
TABERNACLE_DB_KEY=
TABERNACLE_JWT_SECRET=
TABERNACLE_SYNC_TOKEN=
TABERNACLE_SYNC_CHURCH_ID=

# ─── Compte admin initial (obligatoire en production) ──────────────────────
TABERNACLE_BOOTSTRAP_EMAIL=admin@votre-domaine.com
TABERNACLE_BOOTSTRAP_PASSWORD=ChangezMoi-Tres-Fort-2026!
TABERNACLE_BOOTSTRAP_NAME=Administrateur
TABERNACLE_BOOTSTRAP_RESET=false

# ─── OAuth2 / OIDC (Google, Microsoft) ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
OAUTH_REDIRECT_BASE=http://127.0.0.1:3847
OAUTH_APP_RETURN_URL=http://127.0.0.1:5173/oauth/callback

# ─── Alertes & options ─────────────────────────────────────────────────────
TABERNACLE_ALERT_SOLDE_USD_MICRO=1000000
TABERNACLE_DISABLE_AUTO_BACKUP=0

# ─── Mode direct (sans Caddy) ────────────────────────────────────────────
APP_PORT=3847
PORT=3847
HOST=127.0.0.1
