{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tabernacle de la Moisson ERP",
  "version": "1.6.1",
  "identifier": "com.tabernacle.moisson.erp",
  "build": {
    "beforeDevCommand": "node ../../scripts/tauri-before-dev.mjs",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "node ../../scripts/tauri-before-build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tabernacle de la Moisson ERP",
        "width": 1366,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https:; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/app/": "app/",
      "resources/node/": "node/",
      "resources/scripts/": "scripts/",
      "resources/config/": "config/"
    }
  }
}
