{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tabernacle de la Moisson ERP",
  "version": "1.3.1",
  "identifier": "com.tabernacle.moisson.erp",
  "build": {
    "beforeDevCommand": "node ../../../scripts/tauri-before-dev.mjs",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "node ../../../scripts/tauri-before-build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tabernacle de la Moisson ERP",
        "url": "http://127.0.0.1:3847",
        "width": 1366,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:3847 http://localhost:5173; connect-src 'self' http://127.0.0.1:3847 http://localhost:5173 ws://localhost:5173; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:5173"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"]
  }
}
