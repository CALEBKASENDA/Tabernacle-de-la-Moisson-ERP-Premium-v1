# Nom de domaine pointant vers l'IP de votre VM (obligatoire pour HTTPS automatique)
DOMAIN=erp.votre-domaine.com

# E-mail Let's Encrypt (recommandé en production)
ACME_EMAIL=admin@votre-domaine.com

# Église par défaut (première installation)
TABERNACLE_CHURCH_ID=church_default
TABERNACLE_CHURCH_NAME=Tabernacle de la Moisson

# Compte admin initial (créé une seule fois au premier démarrage)
TABERNACLE_BOOTSTRAP_EMAIL=admin@votre-domaine.com
TABERNACLE_BOOTSTRAP_PASSWORD=ChangezMoi-Tres-Fort-2026!
TABERNACLE_BOOTSTRAP_NAME=Administrateur

# Chiffrement SQLCipher (recommandé)
# TABERNACLE_DB_KEY=votre_phrase_secrete_longue

# Sync cloud — même token sur poste local et serveur VM
# TABERNACLE_SYNC_TOKEN=generer-un-token-long-et-aleatoire
# TABERNACLE_SYNC_CHURCH_ID=church_default

# Alerte solde faible (micro-USD)
# TABERNACLE_ALERT_SOLDE_USD_MICRO=1000000000

# Port local si profil "direct" (sans Caddy)
APP_PORT=3847
